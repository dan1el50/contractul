# Copy to .env before starting the stack:
#   cp .env.example .env          (PowerShell: Copy-Item .env.example .env)
#
# Every variable the stack reads is listed here, with defaults safe for local
# development. .env itself is gitignored and must never be committed.
#
# Adding a variable? Add it here too, in the same commit. Someone else's stack
# breaks otherwise, and they have no way to know why.

# ─── Database ────────────────────────────────────────────────────────────────
# Local development only. Real deployments get real secrets from elsewhere.
POSTGRES_USER=contractul
POSTGRES_PASSWORD=contractul_dev_password
POSTGRES_DB=contractul

# ─── Backend ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# Origins allowed to call the API, comma-separated.
CORS_ORIGINS=http://localhost:5173

# Where rendered documents are written inside the container. Backed by a
# Docker volume, so it survives restarts but not `docker compose down -v`.
DOCUMENT_STORAGE_PATH=/var/lib/contractul/documents

# Trust X-Forwarded-For for the client IP. Keep false until a reverse proxy is
# in front — with none, the header is attacker-supplied and turning this on
# lets anyone dodge every rate limit. When enabling it, configure the proxy to
# OVERWRITE the header with the real peer, not append to it.
TRUST_FORWARDED_FOR=false

# Auth rate limits, per client IP. Login guards password brute force; register
# guards email enumeration (its 409 confirms an account) and signup spam.
# Windows are in seconds.
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600

# ─── Frontend ────────────────────────────────────────────────────────────────
# Read by the browser, so this is the host-visible address of the API —
# not the Compose service name. The browser is not inside the network.
VITE_API_URL=http://localhost:8000
